# Next/Auth.js
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Email provider for Auth.js magic links
RESEND_API_KEY="re_replace_with_resend_api_key"
EMAIL_FROM="StitchHarbor <noreply@example.com>"

# PostgreSQL
POSTGRES_USER="stitchharbor"
POSTGRES_PASSWORD="stitchharbor"
POSTGRES_DB="stitchharbor"
DATABASE_URL="postgres://stitchharbor:stitchharbor@localhost:5432/stitchharbor"

# S3-compatible object storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="stitchharbor"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"
