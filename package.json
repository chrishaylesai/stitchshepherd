{
  "name": "stitchharbor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @stitchharbor/db db:generate",
    "db:migrate": "pnpm --filter @stitchharbor/db db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5.8.3"
  }
}
